# ==============================================================================
# Harness Engineering - Environment Variables Template
# 이 파일을 .env.local 로 복사하여 실제 값을 입력하십시오.
# 절대 .env.local 을 커밋하지 마세요.
# ==============================================================================

# 1. Slack Telemetry (작업 완료/실패 알림)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 2. GitHub
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USER_NAME="Your Name"
GITHUB_USER_EMAIL="you@example.com"

# 3. Harness
TASK_ID=local

# 4. AI Provider (run-agent.sh 에서 사용)
# 사용할 provider 선택: openai | anthropic | gemini
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5

# Google Gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
